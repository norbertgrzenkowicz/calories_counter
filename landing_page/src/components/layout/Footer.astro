---
import { getSiteCopy, siteConfig, type Locale } from "../../data/site";
import { getLocalizedPath } from "../../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const siteCopy = getSiteCopy(locale);
---
<footer class="site-footer">
  <div class="shell site-footer__inner">
    <a href={getLocalizedPath(locale, "home")} class="wordmark wordmark--small">{siteConfig.name}</a>
    <nav class="site-footer__nav" aria-label={siteCopy.footerAriaLabel}>
      <a href={getLocalizedPath(locale, "privacy")}>{siteCopy.footerNav.privacy}</a>
      <a href={getLocalizedPath(locale, "terms")}>{siteCopy.footerNav.terms}</a>
      <a href={getLocalizedPath(locale, "contact")}>{siteCopy.footerNav.contact}</a>
    </nav>
    <p class="site-footer__copy">
      © 2026 {siteConfig.name}. {siteCopy.footerTagline}
    </p>
  </div>
</footer>
