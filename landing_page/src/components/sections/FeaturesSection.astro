---
import type { LandingContent } from "../../data/landing";
import Icon from "../ui/Icon.astro";
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  content: LandingContent["featuresSection"];
}

const { content } = Astro.props;
---
<section class="section" id="features">
  <div class="section-heading section-heading--offset">
    <SectionLabel>{content.label}</SectionLabel>
    <h2>{content.title}</h2>
  </div>
  <div class="feature-grid">
    {
      content.items.map((feature) => (
        <article class="feature-card">
          <div class="feature-card__icon-wrap">
            <Icon name={feature.icon} class="feature-card__icon" />
          </div>
          <p class="feature-card__eyebrow">{feature.eyebrow}</p>
          <h3>{feature.title}</h3>
          <p>{feature.body}</p>
        </article>
      ))
    }
  </div>
</section>
