---
import type { LandingContent } from "../../data/landing";
import ButtonLink from "../ui/ButtonLink.astro";
import WaitlistForm from "../ui/WaitlistForm.astro";

interface Props {
  content: LandingContent["hero"];
}

const { content } = Astro.props;
---
<section class="section section--hero">
  <div class="hero only-desktop">
    <div class="hero__copy">
      <p class="hero__eyebrow">{content.eyebrow}</p>
      <h1>{content.title}</h1>
      <p class="hero__body">{content.description}</p>
      <div class="hero__waitlist">
        <WaitlistForm waitlist={content.waitlist} idPrefix="hero-desktop" />
      </div>
      <p class="hero__proof">{content.proof}</p>
    </div>
    <div class="hero__visual">
      <div class="device-card">
        <img
          src="/images/app-screenshot.jpg"
          alt="Yapper app screenshot showing meal analysis, nutrition breakdown, and daily tracking."
          class="device-card__screenshot"
          loading="eager"
        />
      </div>
    </div>
  </div>

  <div class="hero-mobile only-mobile">
    <div class="hero-mobile__copy">
      <p class="hero-mobile__eyebrow">{content.eyebrow}</p>
      <h1 class="hero-mobile__title">{content.title}</h1>
      <p class="hero-mobile__body">{content.description}</p>
      <div class="hero-mobile__actions">
        <ButtonLink href={content.primaryCta.href}>{content.primaryCta.label}</ButtonLink>
        <ButtonLink href={content.secondaryCta.href} variant="secondary">
          {content.secondaryCta.label}
        </ButtonLink>
      </div>
      <WaitlistForm waitlist={content.waitlist} idPrefix="hero-mobile" variant="stacked" />
      <p class="hero-mobile__proof">{content.proof}</p>
    </div>
    <div class="hero-mobile__visual-wrap">
      <div class="hero-mobile__visual">
        <div class="device-card device-card--mobile">
          <img
            src="/images/app-screenshot.jpg"
            alt="Yapper app screenshot showing meal analysis, nutrition breakdown, and daily tracking."
            class="device-card__screenshot"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>
