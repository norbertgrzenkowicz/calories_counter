---
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import type { LandingContent } from "../data/landing";
import { getSiteCopy, siteConfig, type Locale, type RouteKey } from "../data/site";
import { buildMeta } from "../lib/seo";
import "../styles/tokens.css";
import "../styles/global.css";

interface Props {
  locale: Locale;
  routeKey: RouteKey;
  navItems: LandingContent["navItems"];
  title?: string;
  description?: string;
}

const { locale, routeKey, navItems, title, description } = Astro.props;
const meta = buildMeta({ locale, routeKey, title, description });
const siteCopy = getSiteCopy(locale);
---
<!doctype html>
<html lang={siteCopy.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={meta.canonical} />
    {
      meta.alternates.map((alternate) => (
        <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={meta.xDefault} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={meta.canonical} />
    <meta property="og:image" content={`${siteConfig.url}/og-cover.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="theme-color" content="#0A0A0A" />
  </head>
  <body>
    <div class="page-frame">
      <Header locale={locale} routeKey={routeKey} navItems={navItems} />
      <main class="shell page-content">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
  </body>
</html>
