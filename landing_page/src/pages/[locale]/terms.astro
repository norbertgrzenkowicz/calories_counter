---
import { getLandingContent } from "../../data/landing";
import { getTermsContent } from "../../data/legal/terms";
import { getSiteCopy } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { DEFAULT_LOCALE, isLocale, SUPPORTED_LOCALES } from "../../lib/i18n";

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const locale = isLocale(Astro.params.locale) ? Astro.params.locale : DEFAULT_LOCALE;
const landing = getLandingContent(locale);
const termsContent = getTermsContent(locale);
const siteCopy = getSiteCopy(locale);
---
<BaseLayout
  locale={locale}
  routeKey="terms"
  navItems={landing.navItems}
  title={termsContent.title}
  description={termsContent.description}
>
  <section class="legal-page">
    <p class="section-label">{termsContent.eyebrow}</p>
    <h1>{termsContent.title}</h1>
    <p class="legal-page__lede">{termsContent.intro}</p>
    <p class="legal-page__updated">{siteCopy.updatedLabel} {termsContent.updatedAt}</p>
    <div class="legal-page__sections">
      {
        termsContent.sections.map((section) => (
          <article class="legal-card">
            <h2>{section.heading}</h2>
            <p>{section.body}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
