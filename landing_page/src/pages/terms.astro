---
import { termsContent } from "../data/legal/terms";
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title={termsContent.title} pathname="/terms">
  <section class="legal-page">
    <p class="section-label">Legal</p>
    <h1>{termsContent.title}</h1>
    <p class="legal-page__lede">{termsContent.intro}</p>
    <p class="legal-page__updated">Updated {termsContent.updatedAt}</p>
    <div class="legal-page__sections">
      {
        termsContent.sections.map((section) => (
          <article class="legal-card">
            <h2>{section.heading}</h2>
            <p>{section.body}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
